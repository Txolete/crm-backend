# ==================================================================
# CRM SEGUIMIENTO CLIENTES - CONFIGURATION
# Version 0.7.0 - PASO 9
# ==================================================================
#
# IMPORTANT: Rename this file to ".env" before running the application
#
# This file contains all configuration settings for your CRM.
# Follow the instructions below to configure each section.
#
# ==================================================================

# ------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------
# SQLite database file location (relative to project root)
# Default: sqlite:///./crm.db (creates crm.db in project folder)
# For PostgreSQL (future): postgresql://user:pass@host:port/dbname
DATABASE_URL=sqlite:///./crm.db

# ------------------------------------------------------------------
# SECURITY - CRITICAL!
# ------------------------------------------------------------------
# SECRET_KEY: Used to sign JWT tokens. MUST be changed in production!
# Generate a secure key by running:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# NEVER share this key or commit it to version control!
SECRET_KEY=your-secret-key-change-this-in-production

# ------------------------------------------------------------------
# BOOTSTRAP ADMIN (First-time setup)
# ------------------------------------------------------------------
# These credentials will be used to create an admin user automatically
# on first startup if no users exist in the database
# CHANGE THESE VALUES BEFORE FIRST RUN!
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=admin123456
ADMIN_BOOTSTRAP_NAME=Admin User

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Cookie Configuration
COOKIE_NAME=crm_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_MAX_AGE=2592000

# ------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ------------------------------------------------------------------
# List of allowed origins (comma-separated)
# For local use: http://localhost:8000
# For network access: add http://192.168.1.XXX:8000 (your local IP)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOW_CREDENTIALS=true

# ------------------------------------------------------------------
# AUTOMATIONS (PASO 8)
# ------------------------------------------------------------------
# Enable/disable automatic daily tasks
# Set to "false" to disable all automations
AUTOMATIONS_ENABLED=true

# Time to run daily automations (HH:MM format, 24-hour)
# Default: 07:00 (7:00 AM)
AUTO_RUN_TIME=07:00

# Days without activity before creating follow-up task for opportunity
AUTO_NO_ACTIVITY_DAYS=14

# Days without activity before creating follow-up task for proposal stage
AUTO_PROPOSAL_NO_ACTIVITY_DAYS=7

# Deduplication windows (prevent duplicate alerts)
# Don't alert same overdue task for X days
AUTO_OVERDUE_DEDUP_DAYS=7

# Don't create duplicate follow-up tasks within X days
AUTO_FOLLOWUP_DEDUP_DAYS=14

# ------------------------------------------------------------------
# EMAIL NOTIFICATIONS (PASO 8)
# ------------------------------------------------------------------
# Enable/disable email notifications
# Set to "false" if you don't want to send emails
EMAIL_ENABLED=true

# SMTP Server Configuration
# For Gmail:
#   1. Enable 2-factor authentication
#   2. Generate App Password: https://myaccount.google.com/apppasswords
#   3. Use app password below (not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_TLS=true

# Email sender information
SMTP_FROM_NAME=CRM Notifications
SMTP_FROM_EMAIL=your-email@gmail.com

# Dashboard URL (used in email links)
# Change this if accessing CRM from network
EMAIL_DASHBOARD_URL=http://localhost:8000/dashboard

# ==================================================================
# END OF CONFIGURATION
# ==================================================================
#
# QUICK START:
# 1. Rename this file to ".env"
# 2. Generate and set a secure SECRET_KEY
# 3. Configure email settings (or set EMAIL_ENABLED=false)
# 4. Run START_CRM.bat to start the application
#
# For help, see: docs/GUIA_ADMIN.md
#
# ==================================================================
